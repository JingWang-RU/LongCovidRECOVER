   "source": [
    "---\n",
    "## TODO 2 — Reproducibility Check\n",
    "Run Grace Cycle on **3 independent 50% subsamples**.\n",
    "Reports the converging hypothesis and phenotype counts → **Table S2**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "k1000000",
   "metadata": {},
   "outputs": [],
   "source": [
    "HYPOTHESIS_POOL = [\n",
    "    \"Does Long COVID severity decrease spontaneously over time?\",\n",
    "    \"Is Long COVID recovery associated with cumulative vaccine doses?\",\n",
    "    \"Is Long COVID symptom severity related to respiratory rate?\",\n",
    "]\n",
    "\n",
    "def run_grace_cycle_subsample(\n",
    "    df: pd.DataFrame,\n",
    "    subsample_frac: float = 0.5,\n",
    "    n_sample: int = 200,\n",
    "    batch_size: int = 10,\n",
    "    seed: int = SEED,\n",
    ") -> dict:\n",
    "    \"\"\"One Grace Cycle run on a random subsample of participants.\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    all_pids = df[\"pid\"].unique()\n",
    "    chosen   = np.random.choice(\n",
    "        all_pids, size=int(len(all_pids) * subsample_frac), replace=False\n",
    "    )\n",
    "    sub = df[df[\"pid\"].isin(chosen)].copy()\n",
    "\n",
    "    converged          = False\n",
    "    converge_hypothesis = None\n",
    "    iteration_log      = []\n",
    "\n",
    "    for i, hypothesis in enumerate(HYPOTHESIS_POOL):\n",
    "        sample_pids = np.random.choice(\n",
    "            sub[\"pid\"].unique(),\n",
    "            size=min(n_sample, sub[\"pid\"].nunique()),\n",
    "            replace=False,\n",
    "        )\n",
    "        batch_pids = sample_pids[:batch_size]\n",
    "        histories  = \"\\n\\n\".join(\n",
    "            serialise_patient(p, sub[sub[\"pid\"] == p]) for p in batch_pids\n",
    "        )\n",
    "        prompt = (\n",
    "            \"You are a clinical data analyst reviewing longitudinal patient records.\\n\"\n",
    "            \"PASC score measures symptom burden (0–44 scale); lower is better.\\n\"\n",
    "            \"A score ≥ 12 indicates active Long COVID.\\n\\n\"\n",
    "            f\"{histories}\\n\\n\"\n",
    "            f\"Hypothesis: {hypothesis}\\n\\n\"\n",
    "            \"Begin your answer with SUPPORTED, UNSUPPORTED, or PARTIAL, \"\n",
    "            \"then provide a brief justification.\"\n",
    "        )\n",
    "        response = call_llm(prompt)\n",
    "        tag      = parse_llm_tag(response)\n",
    "        iteration_log.append({\n",
    "            \"iteration\": i,\n",
    "            \"hypothesis\": hypothesis,\n",
    "            \"llm_tag\": tag,\n",
    "            \"response_snippet\": response[:300],\n",
    "        })\n",
    "        if tag == \"SUPPORTED\":\n",
    "            converged           = True\n",
    "            converge_hypothesis = hypothesis\n",
    "            break\n",
    "\n",
    "    phenotype_counts = {}\n",
    "    if \"subphenotype\" in sub.columns:\n",
    "        phenotype_counts = (\n",
    "            sub.drop_duplicates(\"pid\")[\"subphenotype\"]\n",
    "            .value_counts()\n",
    "            .to_dict()\n",
    "        )\n",
    "\n",
    "    return {\n",
    "        \"converged\": converged,\n",
    "        \"converge_hypothesis\": converge_hypothesis,\n",
    "        \"phenotype_counts\": phenotype_counts,\n",
    "        \"iteration_log\": iteration_log,\n",
    "    }\n",
    "\n",
    "print(\"Function defined.\")"
   ]
  },
