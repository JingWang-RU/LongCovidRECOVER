  {
   "cell_type": "markdown",
   "id": "h1000000",
   "metadata": {},
   "source": [
    "---\n",
    "## TODO 1 — Dataset Statistics\n",
    "Adds total observations, mean follow-up duration, and vaccine-event count\n",
    "needed for the Methods / Dataset section."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "i1000000",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Total PASC observations ────────────────────────────────────────────────\n",
    "n_pasc_obs = df[\"pasc\"].notna().sum()\n",
    "\n",
    "# ── Follow-up duration per participant (first → last visit) ────────────────\n",
    "followup_days = (\n",
    "    df.groupby(\"pid\")[\"visit_date\"]\n",
    "    .agg(lambda x: (x.max() - x.min()).days)\n",
    ")\n",
    "mean_fu   = followup_days.mean()\n",
    "median_fu = followup_days.median()\n",
    "sd_fu     = followup_days.std()\n",
    "\n",
    "# ── Vaccine-record events ──────────────────────────────────────────────────\n",
    "n_vax_events = df[\"vaccine_date\"].notna().sum()\n",
    "\n",
    "stats_summary = pd.DataFrame({\n",
    "    \"Metric\": [\n",
    "        \"N participants\",\n",
    "        \"N PASC observations\",\n",
    "        \"N vaccine-record events\",\n",
    "        \"Mean follow-up (days)\",\n",
    "        \"Median follow-up (days)\",\n",
    "        \"SD follow-up (days)\",\n",
    "    ],\n",
    "    \"Value\": [\n",
    "        df[\"pid\"].nunique(),\n",
    "        n_pasc_obs,\n",
    "        n_vax_events,\n",
    "        round(mean_fu, 1),\n",
    "        round(median_fu, 1),\n",
    "        round(sd_fu, 1),\n",
    "    ],\n",
    "})\n",
    "\n",
    "display(stats_summary)\n",
    "stats_summary.to_csv(OUTPUT_DIR / \"TODO1_dataset_stats.csv\", index=False)\n",
    "print(\"Saved → supplementary/TODO1_dataset_stats.csv\")"
   ]
  },
