    "# Grace Cycle — TODO Scripts\n",
    "This notebook addresses all four TODO items in `chil-lc.tex`:\n",
    "- **TODO 1**: Dataset statistics (total observations, mean follow-up, vaccine events)\n",
    "- **TODO 2**: Reproducibility check (3 × 50% independent subsamples → Table S2)\n",
    "- **TODO 3**: Prompt sensitivity check (3 prompt variants → Table S3)\n",
    "- **TODO 4**: Negative control — vaccine brand Moderna vs. Pfizer (→ Table S4)\n",
    "\n",
    "**Requirements:**\n",
    "```\n",
    "pip install pandas numpy scipy ollama tqdm\n",
    "```\n",
    "Make sure `ollama serve` is running locally before executing LLM cells."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b1000000",
   "metadata": {},
   "source": [
    "---\n",
    "## 0. Configuration & Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c1000000",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import random\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from scipy import stats\n",
    "from tqdm.notebook import tqdm\n",
    "\n",
    "# ── USER CONFIG ────────────────────────────────────────────────────────────\n",
    "DATA_PATH   = \"/path/to/recover.csv\"   # ← change this\n",
    "LLM_MODEL   = \"llama3\"                 # ← Ollama model name\n",
    "OUTPUT_DIR  = Path(\"./supplementary\")\n",
    "SEED        = 42\n",
    "# ──────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "# Column map: keys are internal names, values are your CSV header names\n",
    "COLUMN_MAP = dict(\n",
    "    pid          = \"participant_id\",\n",
    "    pasc         = \"pasc_score\",\n",
    "    visit_date   = \"visit_date\",\n",
    "    vaccine_date = \"vaccine_date\",\n",
    "    dose_num     = \"vaccine_dose_number\",\n",
    "    brand        = \"vaccine_brand\",      # \"Moderna\" | \"Pfizer\" | ...\n",
    "    sex          = \"sex\",\n",
    "    race         = \"race\",\n",
    "    ethnicity    = \"ethnicity\",\n",
    "    age          = \"age\",\n",
    "    subphenotype = \"subphenotype\",       # Protected | Responder | Refractory\n",
    ")\n",
    "\n",
    "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "random.seed(SEED)\n",
    "np.random.seed(SEED)\n",
    "print(\"Config OK. Output dir:\", OUTPUT_DIR.resolve())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d1000000",
   "metadata": {},
   "source": [
    "---\n",
    "## Shared Utilities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e1000000",
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_data(path: str) -> pd.DataFrame:\n",
    "    \"\"\"Load CSV and rename columns to internal names.\"\"\"\n",
    "    df = pd.read_csv(\n",
    "        path,\n",
    "        parse_dates=[COLUMN_MAP[\"visit_date\"], COLUMN_MAP[\"vaccine_date\"]],\n",
    "    )\n",
    "    df = df.rename(columns={v: k for k, v in COLUMN_MAP.items()})\n",
    "    return df\n",
    "\n",
    "\n",
    "def serialise_patient(pid: str, df_pid: pd.DataFrame) -> str:\n",
    "    \"\"\"Render one participant's record as a chronological text sequence.\"\"\"\n",
    "    lines = [f\"Participant: {pid}\"]\n",
    "    for _, row in df_pid.sort_values(\"visit_date\").iterrows():\n",
    "        if pd.notna(row.get(\"pasc\")):\n",
    "            lines.append(f\"  {row['visit_date'].date()} | PASC: {row['pasc']:.0f}\")\n",
    "        if pd.notna(row.get(\"vaccine_date\")):\n",
    "            brand = row.get(\"brand\", \"\")\n",
    "            lines.append(\n",
    "                f\"  {row['vaccine_date'].date()} | Vaccine: \"\n",
    "                f\"dose {int(row['dose_num'])} ({brand})\"\n",
    "            )\n",
    "    return \"\\n\".join(lines)\n",
    "\n",
    "\n",
    "def call_llm(prompt: str, model: str = LLM_MODEL) -> str:\n",
    "    \"\"\"Call the local Ollama LLM. Returns response text.\"\"\"\n",
    "    try:\n",
    "        import ollama\n",
    "        response = ollama.chat(\n",
    "            model=model,\n",
    "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "            options={\"temperature\": 0},\n",
    "        )\n",
    "        return response[\"message\"][\"content\"]\n",
    "    except Exception as e:\n",
    "        return f\"[LLM ERROR: {e}]\"\n",
    "\n",
    "\n",
    "def parse_llm_tag(response: str) -> str:\n",
    "    \"\"\"Extract SUPPORTED / PARTIAL / UNSUPPORTED from LLM response.\"\"\"\n",
    "    upper = response.upper()\n",
    "    if upper.startswith(\"SUPPORTED\"):\n",
    "        return \"SUPPORTED\"\n",
    "    if upper.startswith(\"PARTIAL\"):\n",
    "        return \"PARTIAL\"\n",
    "    return \"UNSUPPORTED\"\n",
    "\n",
    "\n",
    "print(\"Utilities defined.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f1000000",
   "metadata": {},
   "source": [
